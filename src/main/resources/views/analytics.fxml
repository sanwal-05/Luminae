<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="TOP_CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hiddeninpixel.ui.controllers.AnalyticsController"
      prefWidth="1100" prefHeight="700">
    <padding><Insets top="20" left="40" right="40" bottom="20"/></padding>
    
    <Label text="Operation History" style="-fx-font-size: 20px; -fx-text-fill: #FDC89C;"/>
    
    <TableView fx:id="analyticsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="algorithmColumn" text="Algorithm" prefWidth="150"/>
            <TableColumn fx:id="resolutionColumn" text="Resolution" prefWidth="150"/>
            <TableColumn fx:id="sizeColumn" text="Payload (KB)" prefWidth="150"/>
            <TableColumn fx:id="ratioColumn" text="Change Ratio (%)" prefWidth="150"/>
            <TableColumn fx:id="timestampColumn" text="Timestamp" prefWidth="200"/>
        </columns>
    </TableView>
    
    <Button text="Refresh Data" onAction="#refreshData"/>
</VBox>
