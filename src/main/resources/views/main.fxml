<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.hiddeninpixel.ui.controllers.MainController"
            prefWidth="1200" prefHeight="800">
    
    <top>
        <HBox alignment="CENTER" spacing="20" styleClass="header">
            <padding><Insets top="20" bottom="20"/></padding>
            <Label text="Hidden-In-Pixel" style="-fx-font-size: 28px; -fx-text-fill: #FEAFC5; -fx-font-weight: bold;"/>
        </HBox>
    </top>
    
    <center>
        <TabPane fx:id="mainTabPane">
            <tabs>
                <Tab text="Steganography" closable="false">
                    <VBox spacing="20" alignment="TOP_CENTER">
                        <padding><Insets top="20" left="40" right="40" bottom="20"/></padding>
                        
                        <!-- Algorithm Selection -->
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="Algorithm:"/>
                            <ComboBox fx:id="algorithmComboBox" prefWidth="200"/>
                            <Button text="Load Image" onAction="#handleLoadImage"/>
                        </HBox>
                        
                        <!-- Image Display -->
                        <HBox spacing="30" alignment="CENTER">
                            <VBox alignment="CENTER" spacing="10">
                                <Label text="Cover Image" styleClass="label"/>
                                <ImageView fx:id="coverImageView" fitWidth="400" fitHeight="300" preserveRatio="true"/>
                            </VBox>
                            
                            <VBox alignment="CENTER" spacing="10">
                                <Label text="Stego Image" styleClass="label"/>
                                <ImageView fx:id="stegoImageView" fitWidth="400" fitHeight="300" preserveRatio="true"/>
                            </VBox>
                        </HBox>
                        
                        <!-- Message Input -->
                        <VBox spacing="10">
                            <Label text="Secret Message:"/>
                            <TextArea fx:id="messageTextArea" prefHeight="100" promptText="Enter your secret message..."/>
                        </VBox>
                        
                        <!-- Key Input -->
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="Password/Key:"/>
                            <PasswordField fx:id="keyPasswordField" prefWidth="300" promptText="Required for XOR/Stochastic"/>
                        </HBox>
                        
                        <!-- Action Buttons -->
                        <HBox spacing="20" alignment="CENTER">
                            <Button text="Hide Message" onAction="#handleHide" prefWidth="150"/>
                            <Button text="Extract Message" onAction="#handleExtract" prefWidth="150"/>
                            <Button text="Save Stego Image" onAction="#handleSaveStego" prefWidth="150"/>
                        </HBox>
                        
                        <!-- Status -->
                        <Label fx:id="statusLabel" styleClass="status-label" text="Ready"/>
                        <ProgressBar fx:id="progressBar" prefWidth="600"/>
                    </VBox>
                </Tab>
                
                <Tab text="Analytics" closable="false">
                    <fx:include source="analytics.fxml"/>
                </Tab>
            </tabs>
        </TabPane>
    </center>
    
</BorderPane>
